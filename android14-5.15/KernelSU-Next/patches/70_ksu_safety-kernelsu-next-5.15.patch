diff -ruN clean/kernel/Kbuild work/kernel/Kbuild
--- a/kernel/Kbuild	2026-03-03 19:14:40.927529187 +0100
+++ b/kernel/Kbuild	2026-03-03 19:24:14.856319065 +0100
@@ -3,7 +3,6 @@
